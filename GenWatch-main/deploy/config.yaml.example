# GenWatch deployment configuration.
#
# Installed by the install.sh script to /etc/genwatch/config.yaml. To
# make changes safely:
#
#   sudo nano /etc/genwatch/config.yaml
#   sudo systemctl restart genwatch
#
# Most installations only need to:
#   1. auth.admin_password_hash  ← from: sudo -u genwatch genwatch hash <password>
#   2. auth.jwt_secret           ← auto-generated by installer (don't change)
#   3. transport + endpoint      ← modbus_tcp.host:port (Lantronix etc.) or serial.device
#   4. modbus.slave              ← 100 for stock H-100 (factory default)
#
# Anything not set here falls back to package defaults.

# Set to true to disable real Modbus I/O and use the synthesized H-100
# state machine. Useful for previewing the UI before the bridge is
# wired or for offline UI development. Leave false in production: with
# a real transport configured, the service stays up even when the link
# is down (surfacing "Comms LOST" in the UI) and reconnects in the
# background — it never silently invents telemetry.
mock: false

# Which Modbus link to use:
#   tcp    — Modbus-RTU framed over a TCP socket. The expected setup is a
#            Lantronix UDS / EDS / xDirect (or Moxa NPort / Digi PortServer
#            / ser2net) that tunnels raw bytes between the network and a
#            physical RS-232/RS-485 port wired to the H-100. This is *not*
#            Modbus/TCP (port 502, MBAP header) — it's still RTU framing,
#            just travelling over TCP. Default Lantronix raw-TCP port is
#            10001. Configure on the bridge's web UI under
#            Channel 1 → Connection → Connect Mode = "Always" (passive).
#   serial — direct USB-to-serial cable plugged into this Pi. Use this if
#            the Pi is next to the generator and you don't want a network
#            bridge in the critical path.
transport: tcp

# Used when transport: tcp.
modbus_tcp:
  host: 192.168.1.249     # Lantronix LAN address
  port: 10001             # Lantronix Channel 1 default raw-TCP port
  timeout_s: 1.5          # per-request — bump if LAN latency is high
  connect_timeout_s: 3.0  # startup probe; affects how fast we fail boot
  framer: rtu             # H-100 frames RTU. Don't change unless your
                          # device actually exposes Modbus/TCP framing.

# Used when transport: serial. Left in place so you can flip transport
# back to 'serial' without losing cable settings.
serial:
  # /dev/genwatch-modbus is the stable symlink created by the bundled
  # udev rule (covers FTDI / CH340 / CP210x / PL2303 USB-to-serial chips
  # in both RS-232 cables and RS-485 modules). If your adapter isn't
  # recognized it will fall back to /dev/ttyUSB0; the installer prints
  # what it sees during setup.
  device: /dev/genwatch-modbus
  baud: 9600              # H-100 RS-232 default. RS-485 default is 4800.
  parity: N
  stopbits: 1             # H-100 RS-232 default. RS-485 default is 2.
  bytesize: 8
  timeout_s: 1.5

modbus:
  slave: 100              # 0x64 — H-100 factory default
  read_fc: 3              # 0x03 — read holding registers
  prime_poll_ms: 1500     # state + alarms cadence
  base_poll_ms: 15000     # full telemetry cadence
  retries: 2
  # Path is resolved against the package's bundled registers/ dir if
  # relative, else absolute. Edit registers/h100.yaml in place to adjust
  # per-site addresses; hot-reload via POST /api/registers/reload (admin).
  register_file: registers/h100.yaml

retention:
  raw_days: 7             # every-15s rows in `telemetry`
  rollup_1m_days: 90      # minute-bucketed averages
  rollup_1h_days: 730     # hour-bucketed averages (2 years)
  events_days: 30         # info/ok events; alarms+warns are kept forever
  audit_days: 0           # 0 = never delete audit log

auth:
  # bcrypt hash — generate with: sudo -u genwatch genwatch hash 'your-pw'
  admin_password_hash: "REPLACE_ME"
  # JWT signing secret — installer auto-generates this; only change if
  # you want to invalidate all existing sessions.
  jwt_secret: "REPLACE_ME"
  operator_name: operator
  session_hours: 12
  # ── Session-cookie hardening ───────────────────────────────────────
  # Leave both at their defaults unless you have a specific reason. The
  # defaults are safe for the three documented deployment topologies
  # (plain LAN, Caddy, Tailscale).
  #
  # cookie_secure:
  #   unset (null) → auto-detect from the request. HTTPS in front (Caddy
  #                  /Tailscale terminating TLS on the same host) gives
  #                  Secure for free; plain-HTTP LAN stays non-Secure.
  #   true          → force Secure on every response. Use behind an HTTPS
  #                  reverse proxy that doesn't forward X-Forwarded-Proto.
  #   false         → never Secure. Only for local dev.
  # cookie_secure: null
  #
  # cookie_samesite — strict | lax | none.
  #   'strict' (default) blocks the JWT from being sent on cross-site
  #   navigations, defense-in-depth against CSRF on top of the two-step
  #   confirm tokens. UX cost: clicking a link from Slack/email into
  #   GenWatch shows the login page once (cookie not sent on the initial
  #   cross-site nav) and the operator logs in normally.
  # cookie_samesite: strict

# ─── Slack alerts ─────────────────────────────────────────────────────────
# Forwards alarms, alarm-clears, operator commands, and (optionally)
# state/comms transitions to a Slack channel.
#
# Setup:
#   1. Create a Slack app:  https://api.slack.com/apps  →  "From scratch"
#   2. OAuth & Permissions  →  Bot Token Scopes  →  add  chat:write
#   3. Install to workspace  →  copy the "Bot User OAuth Token" (xoxb-...)
#   4. Invite the bot to your alert channel:  /invite @YourBotName
#   5. Paste the token below, set enabled: true, set channel, restart.
#
# Slack settings can also be edited through the Settings → Alerts page
# in the UI (admin role); the UI hot-reloads without a service restart.
slack:
  enabled: false
  bot_token: ""           # xoxb-... — keep secret! file mode is 0640.
  channel: ""             # "#genwatch-alerts" or channel id "C0123ABCD"
  site_label: ""          # overrides site.name in Slack messages, optional
  alert_on_alarm: true            # alarm-severity events (engine shutdowns, etc.)
  alert_on_warning: true          # warn-severity events (low battery, etc.)
  alert_on_alarm_cleared: true    # operator-ack and auto-clears
  alert_on_state_change: false    # every stopped/cranking/running/cooling — chatty
  alert_on_command: true          # operator-issued start/stop/exercise/transfer
  alert_on_comms_lost: true       # Modbus link lost / recovered
  alert_on_load_source_change: true   # utility ↔ generator load transitions

# WebSocket push cadence (ms). Leave at prime_poll_ms unless the UI
# feels sluggish.
ws_push_ms: 1500

# ─── ATS-Pi companion device (optional) ──────────────────────────────────
# When `enabled: true`, GenWatch polls a second Modbus TCP device on the
# LAN — the "ATS-Pi" — that physically observes the ASCO Series 300
# transfer switch. Its `position` register becomes the authoritative
# loadSource for the UI (more accurate than the H-100-derived value).
# When disabled or unreachable, GenWatch silently falls back to the
# H-100-electrical loadSource derivation; no operator-visible change
# other than a "(via gen telemetry)" provenance subscript in the UI.
#
# See:
#   docs/integrations/ats-pi-icd.md      — wire contract
#   docs/integrations/ats-pi-plan.md     — phased integration plan
ats:
  enabled: false
  host: 192.168.1.250
  # Companion starter defaults to 5020 (high port, no root needed on
  # the companion). If you've explicitly configured the companion for
  # 502 (the Modbus TCP convention), switch this to 502 to match.
  port: 5020
  framer: socket            # Modbus/TCP (MBAP). 'rtu' only for RTU-over-TCP.
  slave: 1
  register_file: registers/ats_pi.yaml
  # Optional sanity check — when set, GenWatch refuses to treat the
  # ATS-Pi as authoritative unless its reported ats_pi_unit_id matches.
  # Prevents wrong-site comms in a future multi-site deployment.
  expected_unit_id: 23
